      "article_key": "https://www.straitstimes.com/business/companies-markets/samsung-labour-union-fail-to-reach-pay-deal-strike-looms",
      "canonical_link": "https://www.straitstimes.com/business/companies-markets/samsung-labour-union-fail-to-reach-pay-deal-strike-looms",
