      "article_key": "https://economictimes.indiatimes.com/industry/auto/auto-news/bright-start-to-fy27-for-carmakers-with-estimated-sales-of-4-5-lakh-units-in-april/articleshow/130678046.cms",
      "canonical_link": "https://economictimes.indiatimes.com/industry/auto/auto-news/bright-start-to-fy27-for-carmakers-with-estimated-sales-of-4-5-lakh-units-in-april/articleshow/130678046.cms",
